{
  "expo": {
    "name": "한달음",
    "slug": "handaleum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "handaleum",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.handaleum.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.handaleum.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8F0F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "한 달의 사진을 지도 위에 펼쳐 보여주기 위해 사진 접근 권한이 필요합니다.",
          "savePhotosPermission": "완성한 회고 카드를 사진첩에 저장하기 위해 권한이 필요합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "사진이 찍힌 장소 이름(예: 용인시 - 동천동)을 보여주고, 집 위치를 지정해 집에서 찍은 사진을 회고에서 빼기 위해 위치가 필요합니다."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF9F4",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "organization": "handaleum",
          "project": "handaleum",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a474f67-0e6c-4c05-a251-3099a9289496"
      }
    }
  }
}
