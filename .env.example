# Sentry crash reporting (optional until set)
# Create a project at https://sentry.io → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat public SDK keys (Project settings → API keys)
# iOS App Store key starts with appl_
EXPO_PUBLIC_RC_IOS_KEY=
# Android Play Store key starts with goog_ (when Android ships)
EXPO_PUBLIC_RC_ANDROID_KEY=

# For EAS production source maps (optional):
# eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
# Then set organization/project on the @sentry/react-native plugin in app.json
